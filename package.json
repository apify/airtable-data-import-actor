{
    "name": "airtable-data-import-actor",
    "version": "0.0.1",
    "type": "module",
    "description": "Apify Actor for importing data from Apify datasets to Airtable.",
    "engines": {
        "node": ">=18.0.0"
    },
    "dependencies": {
        "apify": "^3.4.2",
        "crawlee": "^3.13.8",
        "zod": "^4.1.13"
    },
    "devDependencies": {
        "@apify/eslint-config": "^1.0.0",
        "@apify/tsconfig": "^0.1.1",
        "@types/node": "^24.10.1",
        "eslint": "^9.29.0",
        "eslint-config-prettier": "^10.1.5",
        "prettier": "^3.5.3",
        "tsx": "^4.19.2",
        "typescript": "^5.9.3"
    },
    "scripts": {
        "start": "tsx src/main.ts",
        "start:dev": "tsx src/main.ts",
        "start:prod": "node dist/main.js",
        "build": "tsc",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "test": "echo \"Error: oops, the Actor has no tests yet, sad!\" && exit 1"
